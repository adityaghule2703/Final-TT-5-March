<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark gray layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#262930" />
        </shape>
    </item>
    
    <!-- Purple diagonal overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#262930" />
        </shape>
        <rotate android:fromDegrees="15" />
        <size android:width="1000dp" android:height="1000dp" />
    </item>
    
    <!-- Purple diagonal overlay opposite direction -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#262930" />
        </shape>
        <rotate android:fromDegrees="-15" />
        <size android:width="1000dp" android:height="1000dp" />
    </item>
</layer-list>